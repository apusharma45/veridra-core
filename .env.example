# Copy to .env and replace with your real values.
# Required for provider=openai runs:
OPENAI_API_KEY=sk-demo-replace-with-your-real-key

# Required for provider=groq runs:
GROQ_API_KEY=gsk-demo-replace-with-your-real-key

# Optional for provider=ollama runs (local default shown):
OLLAMA_BASE_URL=http://localhost:11434

# Optional for provider=groq runs (default shown):
GROQ_BASE_URL=https://api.groq.com/openai/v1
